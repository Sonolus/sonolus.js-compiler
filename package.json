{
  "name": "@sonolus/sonolus.js-compiler",
  "version": "1.8.3",
  "description": "Sonolus.js Compiler",
  "author": "NonSpicyBurrito",
  "repository": "github:Sonolus/sonolus.js-compiler",
  "license": "MIT",
  "keywords": [
    "Sonolus"
  ],
  "type": "module",
  "exports": {
    "./shared": "./dist/index.shared.js",
    "./play": "./dist/index.play.js",
    "./watch": "./dist/index.watch.js",
    "./preview": "./dist/index.preview.js",
    "./tutorial": "./dist/index.tutorial.js",
    "./internal/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check-type": "tsc -p . --noEmit",
    "check-lint": "oxlint",
    "check-format": "oxfmt --check",
    "build": "tsc -p ."
  },
  "dependencies": {
    "acorn": "^8.17.0"
  },
  "peerDependencies": {
    "@sonolus/core": "~7.15.3",
    "typebox": "^1.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^22.20.1",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
    "typescript": "~6.0.3"
  }
}
