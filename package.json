{
  "name": "@sonolus/sonolus.js-compiler",
  "version": "1.8.2",
  "description": "Sonolus.js Compiler",
  "author": "NonSpicyBurrito",
  "repository": "github:Sonolus/sonolus.js-compiler",
  "license": "MIT",
  "keywords": [
    "Sonolus"
  ],
  "type": "module",
  "exports": {
    "./shared": "./dist/index.shared.js",
    "./play": "./dist/index.play.js",
    "./watch": "./dist/index.watch.js",
    "./preview": "./dist/index.preview.js",
    "./tutorial": "./dist/index.tutorial.js",
    "./internal/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check-type": "tsc -p . --noEmit",
    "check-lint": "eslint .",
    "check-format": "prettier . --check",
    "build": "tsc -p ."
  },
  "dependencies": {
    "acorn": "^8.17.0"
  },
  "peerDependencies": {
    "@sonolus/core": "~7.15.2",
    "typebox": "^1.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^22.20.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
